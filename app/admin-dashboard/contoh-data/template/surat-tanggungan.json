        "html": "<p style=\"text-align: center;\"></p><p style=\"text-align: center;\"><span style=\"font-size: 18pt;\"><strong><u>SURAT TANGGUNGAN</u></strong></span></p><p style=\"text-align: left;\"></p><p style=\"text-align: left;\"></p><p style=\"text-align: left;\"><span style=\"font-size: 10.5pt;\">Kepada Yth.</span></p><p style=\"line-height: 115%; margin-top: 0in; margin-bottom: 8pt;\"><span style=\"font-size: 10.5pt;\">Kepala Desa/Kelurahan</span></p><p style=\"line-height: 115%; margin-top: 0in; margin-bottom: 8pt;\"></p><p style=\"line-height: 1.5; margin-top: 0in; margin-bottom: 8pt;\"><span style=\"font-family: Aptos, sans-serif; font-size: 10.5pt;\">Nama&nbsp;&nbsp;&nbsp;&nbsp;  </span><span style=\"font-family: &quot;Yu Gothic&quot;, sans-serif; font-size: 10.5pt;\">：</span><span style=\"font-family: Aptos, sans-serif; font-size: 10.5pt;\">&lt;nama-peserta-romanji&gt; \t\t\tJenis Kelamin : &lt;jk&gt;</span></p><p style=\"line-height: 1.5; margin-top: 0in; margin-bottom: 8pt;\"><span style=\"font-family: Aptos, sans-serif; font-size: 10.5pt;\">Tgl Lahir </span><span style=\"font-family: &quot;Yu Gothic&quot;, sans-serif; font-size: 10.5pt;\">：</span><span style=\"font-family: Aptos, &quot;Segoe UI&quot;, Calibri, &quot;Helvetica Neue&quot;, Arial, sans-serif; font-size: 10.5pt;\">&lt;tgl-lahir-peserta&gt; \t\t\t\t</span><span style=\"font-family: Aptos, sans-serif; font-size: 10.5pt;\">Kewarganegaraan : Indonesia</span></p><p style=\"line-height: 1.5; margin-top: 0in; margin-bottom: 8pt;\"><span style=\"font-family: Aptos, sans-serif; font-size: 10.5pt;\">NIK&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; : &lt;nik-peserta&gt; \t\t\t\tPenerbit KTP : Dinas Kependudukan dan \t\t\t\t\t\t\t     Pencatatan Sipil</span></p><p style=\"line-height: 1.5; margin-top: 0in; margin-bottom: 8pt;\"></p><p style=\"line-height: 1.5; margin-top: 0in; margin-bottom: 8pt;\"></p><p style=\"line-height: 1.5; margin-top: 0in; margin-bottom: 8pt;\"><span style=\"font-